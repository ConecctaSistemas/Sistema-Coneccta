    "fecharCaixa": "POST /api/pdv/caixa/fechar",
    "criarVenda": "POST /api/pdv/vendas",
    "adicionarItem": "POST /api/pdv/vendas/{id}/itens",
    "cancelarItem": "DELETE /api/pdv/vendas/{id}/itens/{itemId}",
    "cancelarVenda": "POST /api/pdv/vendas/{id}/cancelar",
    "guardarVenda": "POST /api/pdv/vendas/{id}/guardar",
    "recuperarVenda": "GET /api/pdv/vendas/guardadas",
    "receberVenda": "POST /api/pdv/vendas/{id}/recebimento",
    "finalizarVenda": "POST /api/pdv/vendas/{id}/finalizar",
    "emitirNFCe": "POST /api/pdv/vendas/{id}/nfce",
    "selecionarCliente": "GET /api/clientes?busca={termo}",
    "selecionarVendedor": "GET /api/usuarios?vendedor=true",
    "listarTabelaPreco": "GET /api/tabelas-preco"
